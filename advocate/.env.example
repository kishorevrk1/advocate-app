# Advocate Mobile App — Environment Variables
# Copy this file to .env and fill in your values.
# All variables prefixed with EXPO_PUBLIC_ are bundled into the client app and visible to users.
# Never put secrets here — use private variables only in advocate-api/.env.

# ─────────────────────────────────────────────
# Supabase
# Project URL found in: Supabase Dashboard → Project Settings → API → Project URL
# ─────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous (public) key — safe to expose in client code.
# Found in: Supabase Dashboard → Project Settings → API → Project API keys → anon / public
EXPO_PUBLIC_SUPABASE_KEY=your-supabase-anon-key

# ─────────────────────────────────────────────
# Backend API
# Base URL of the advocate-api Express server.
# Local dev:    http://localhost:3001
# Production:   your Railway deployment URL, e.g. https://advocate-api-production.up.railway.app
# ─────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3001

# ─────────────────────────────────────────────
# RevenueCat (in-app purchases)
# Used to initialize the RevenueCat SDK for subscription management.
# Found in: RevenueCat Dashboard → Project → Apps → select your app → API Key (Public SDK key)
# iOS and Android have separate keys — use the key matching your build target.
# Note: RevenueCat does not work in Expo Go; it requires a custom dev client or production build.
# ─────────────────────────────────────────────
EXPO_PUBLIC_REVENUECAT_KEY=your-revenuecat-public-sdk-key

# ─────────────────────────────────────────────
# Mixpanel (analytics)
# Found in: Mixpanel Dashboard → Project Settings → Project Token
# ─────────────────────────────────────────────
EXPO_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-project-token

# ─────────────────────────────────────────────
# Environment flag
# Used to distinguish environments in code. Values: development | staging | production
# ─────────────────────────────────────────────
EXPO_PUBLIC_ENV=development

# Advocate API — Environment Variables
# Copy this file to .env and fill in your values.
# These variables are SERVER-SIDE ONLY and must never be committed or exposed to clients.

# ─────────────────────────────────────────────
# Server
# Port the Express server listens on.
# Railway sets PORT automatically in production — leave as 3001 for local development.
# ─────────────────────────────────────────────
PORT=3001

# ─────────────────────────────────────────────
# Anthropic Claude API
# Used to power case analysis, demand letter generation, and phone scripts (claude-sonnet-4-6).
# Found in: https://console.anthropic.com → API Keys
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─────────────────────────────────────────────
# Supabase
# Project URL — same value as EXPO_PUBLIC_SUPABASE_URL in the mobile app.
# Found in: Supabase Dashboard → Project Settings → API → Project URL
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key — has full database access and bypasses Row Level Security.
# Keep this secret. Never expose it in the mobile app or commit it to version control.
# Found in: Supabase Dashboard → Project Settings → API → Project API keys → service_role
# ─────────────────────────────────────────────
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
